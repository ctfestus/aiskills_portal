# GEMINI_API_KEY: Primary AI provider. Required.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_MODEL: Optional override (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# OPENAI_API_KEY: Fallback AI provider. Used automatically if Gemini fails.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
# OPENAI_MODEL: Optional override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# YOUTUBE_API_KEY: Optional, but recommended for AI lesson video suggestions.
# Used by the course lesson generator to find embeddable YouTube videos.
YOUTUBE_API_KEY="MY_YOUTUBE_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary — sign up at cloudinary.com, get credentials from Dashboard > Settings > API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
