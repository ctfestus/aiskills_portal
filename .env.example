# GEMINI_API_KEY: Primary AI provider. Required.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_MODEL: Optional override (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# OPENAI_API_KEY: Fallback AI provider. Used automatically if Gemini fails.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
# OPENAI_MODEL: Optional override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# YOUTUBE_API_KEY: Optional, but recommended for AI lesson video suggestions.
# Used by the course lesson generator to find embeddable YouTube videos.
YOUTUBE_API_KEY="MY_YOUTUBE_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Security / server-side tokens
# TOKEN_ENCRYPTION_KEY must be a base64-encoded 32-byte key.
TOKEN_ENCRYPTION_KEY=
COURSE_PYTHON_PROOF_SECRET=
CRON_SECRET=
REINDEX_SECRET=
INTAKE_WEBHOOK_SECRET=

# Resend -- transactional email + audience management (resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Optional: Resend Audience ID. When set, new signups are added as contacts automatically.
RESEND_AUDIENCE_ID=

# Upstash Redis / Vector / QStash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_URL=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Cloudinary — sign up at cloudinary.com, get credentials from Dashboard > Settings > API Keys
# CLOUDINARY_CLOUD_NAME is also exposed to the browser (via next.config.ts) so covers stored as
# bare public_ids resolve client-side. The cloud name is non-secret; the key/secret stay server-only.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# GitHub uploads: used for assignment resources and virtual experience datasets/files.
# The repository must be public when the app stores raw.githubusercontent.com URLs.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_REPO_BRANCH=main

# Bunny video library
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_CDN_HOSTNAME=

# Optional search/image providers
PEXELS_API_KEY=
NEXT_PUBLIC_PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
GOOGLE_API_KEY=

# Google Sheets integration
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A:F

# Platform sync
NEXT_PUBLIC_SYNC_ENABLED=false
PLATFORM_SYNC_URL=
PLATFORM_SYNC_KEY=
PLATFORM_SYNC_OWNER_ID=

# Cron tuning
DEADLINE_REMINDER_DAYS=3
NUDGE_INACTIVITY_DAYS=7
NUDGE_RESEND_AFTER_DAYS=14

# Public branding / tenant defaults
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_DESCRIPTION=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_ORG_NAME=
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_LOGO_DARK_URL=
NEXT_PUBLIC_TEAM_NAME=
NEXT_PUBLIC_SENDER_NAME=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_BRAND_COLOR=#2563eb
NEXT_PUBLIC_PRIMARY_COLOR=#2563eb
NEXT_PUBLIC_ACCENT_COLOR=#f59e0b
NEXT_PUBLIC_EMAIL_BANNER_URL=
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=
NEXT_PUBLIC_HERO_TITLE=
NEXT_PUBLIC_HERO_TITLE_ACCENT=
NEXT_PUBLIC_HERO_SUBHEADLINE=
NEXT_PUBLIC_HERO_PRIMARY_CTA=Get started
NEXT_PUBLIC_FOOTER_TAGLINE=
NEXT_PUBLIC_STATS_ENROLLED=
NEXT_PUBLIC_STATS_RATING=

# Local development
DISABLE_HMR=
